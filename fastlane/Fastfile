default_platform(:ios)

platform :ios do
  
  desc "Upload metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: "4JLWR7B5T4",
      issuer_id: "0d7cd2d5-68c7-4214-854f-26b663d40beb",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_4JLWR7B5T4.p8")
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.ufukozdemir.thingcost",
      skip_binary_upload: true,
      skip_app_version_update: true,
      skip_screenshots: true,
      edit_live: false,
      force: true,
      precheck_include_in_app_purchases: false,
      app_review_information: {},
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: "4JLWR7B5T4",
      issuer_id: "0d7cd2d5-68c7-4214-854f-26b663d40beb",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_4JLWR7B5T4.p8")
    )

    build_app(
      scheme: "ThingCost",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.ufukozdemir.thingcost" => "match AppStore com.ufukozdemir.thingcost"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Archive only (no upload)"
  lane :archive do
    build_app(
      scheme: "ThingCost",
      export_method: "app-store",
      clean: true
    )
  end

end
